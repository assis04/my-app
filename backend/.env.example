# Configurações de Servidor
PORT=3001
NODE_ENV=production

# Segurança e Autenticação
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=gere_uma_chave_de_pelo_menos_32_caracteres_aqui
JWT_REFRESH_SECRET=gere_outra_chave_diferente_de_pelo_menos_32_caracteres

# Banco de Dados (PostgreSQL)
# Exemplo: postgresql://usuario:senha@localhost:5432/nome_do_banco
DATABASE_URL=postgresql://user:password@localhost:5432/ambisistem_crm
POSTGRE_HOST=localhost
POSTGRE_PORT=5432
POSTGRE_USERNAME=user
POSTGRE_PASSWORD=password
POSTGRE_DATABASE=ambisistem_crm

# Seed — senha do admin inicial (usado apenas no seed, nunca em runtime)
ADMIN_SEED_PASSWORD=defina_uma_senha_forte_aqui

# Redis (para blacklist de tokens e rate limiting)
REDIS_HOST=redis
REDIS_PORT=6379

# CORS - IMPORTANTE PARA PRODUÇÃO
# Este é o endereço onde o seu frontend (site) estará rodando.
# Ex: https://crm.suaempresa.com ou https://ambisistem.vercel.app
CORS_ORIGIN=http://localhost:3000
