// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id          Int      @id @default(autoincrement())
  nome        String   @unique
  descricao   String?
  permissions String[] @default([]) // Array de strings para guardar os módulos permitidos
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id                 Int       @id @default(autoincrement())
  nome               String
  email              String    @unique
  password           String
  roleId             Int?      @map("role_id")
  role               Role?     @relation(fields: [roleId], references: [id])
  filialId           Int?      @map("filial_id")
  filial             Filial?   @relation(fields: [filialId], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  ativo              Boolean   @default(true)
  deletedAt          DateTime? @map("deleted_at")
  mustChangePassword Boolean   @default(true) @map("must_change_password")

  // Audit Log: Who created this user?
  createdById  Int?   @map("created_by_id")
  createdBy    User?  @relation("UserCreator", fields: [createdById], references: [id])
  createdUsers User[] @relation("UserCreator")

  // Equipe and Branch Management
  equipeId       Int?     @map("equipe_id")
  equipe         Equipe?  @relation("EquipeMembros", fields: [equipeId], references: [id])
  equipeLiderada Equipe[] @relation("EquipeLider")
  managedBranch  Filial[] @relation("BranchManager")

  // Tasks (Lista de Tarefas)
  tasksCreated  Task[] @relation("TaskCreator")
  tasksAssigned Task[] @relation("AssignedTasks")

  salesQueues   SalesQueue[]
  leadsAssigned Lead[]       @relation("LeadPreVendedor")
  leadsVendedor Lead[]       @relation("LeadVendedor")
  leadsGerente  Lead[]       @relation("LeadGerente")

  @@map("users")
}

model Filial {
  id          Int          @id @default(autoincrement())
  nome        String       @unique
  endereco    String?
  users       User[]
  leads       Lead[]
  equipes     Equipe[]
  salesQueues SalesQueue[]

  // Manager of the branch
  managerId Int?  @map("manager_id")
  manager   User? @relation("BranchManager", fields: [managerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("filiais")
}

model Equipe {
  id        Int     @id @default(autoincrement())
  nome      String  @unique
  descricao String?
  ativo     Boolean @default(true)

  // Líder da equipe (um usuário)
  liderId Int?  @map("lider_id")
  lider   User? @relation("EquipeLider", fields: [liderId], references: [id])

  // Filial da equipe
  filialId Int?    @map("filial_id")
  filial   Filial? @relation(fields: [filialId], references: [id])

  // Membros da equipe
  membros User[] @relation("EquipeMembros")

  // Tarefas da Equipe
  tasks Task[] @relation("EquipeTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipes")
}

model SalesQueue {
  filialId       Int       @map("branch_id")
  filial         Filial    @relation(fields: [filialId], references: [id])
  userId         Int       @map("user_id")
  user           User      @relation(fields: [userId], references: [id])
  isAvailable    Boolean   @default(true) @map("is_available")
  lastAssignedAt DateTime? @map("last_assigned_at")
  attendCount30d Int       @default(0) @map("attend_count_30d")
  position       Int       @default(0)

  @@id([filialId, userId]) // Composite Key
  @@map("branch_sales_queues")
}

model Lead {
  id Int @id @default(autoincrement())

  // === Identidade ===
  nome      String
  sobrenome String?
  celular   String
  email     String?
  cpfCnpj   String? @map("cpf_cnpj")
  cep       String?
  endereco  String?

  // === CRM / Pipeline ===
  idKanban                String? @map("id_kanban")
  status                  String  @default("Novo")
  etapa                   String?
  temperatura             String?
  statusAntesCancelamento String? @map("status_antes_cancelamento")

  // === Imóvel (domínio imobiliário) ===
  tipoImovel       String? @map("tipo_imovel")
  statusImovel     String? @map("status_imovel")
  plantaPath       String? @map("planta_path")
  pedidosContratos String? @map("pedidos_contratos")

  // === Marketing / Origem ===
  canal         String?
  origem        String?
  parceria      String?
  origemCanal   String? @map("origem_canal")
  origemExterna Boolean @default(false) @map("origem_externa")

  // === Cônjuge ===
  conjugeNome      String? @map("conjuge_nome")
  conjugeSobrenome String? @map("conjuge_sobrenome")
  conjugeCelular   String? @map("conjuge_celular")
  conjugeEmail     String? @map("conjuge_email")

  // === Vendedor (atribuição via fila) ===
  vendedorId Int?  @map("vendedor_id")
  vendedor   User? @relation("LeadVendedor", fields: [vendedorId], references: [id])

  // === Pré-vendedor (CRM) ===
  preVendedorId Int?  @map("pre_vendedor_id")
  preVendedor   User? @relation("LeadPreVendedor", fields: [preVendedorId], references: [id])

  // === Gerente ===
  gerenteId Int?  @map("gerente_id")
  gerente   User? @relation("LeadGerente", fields: [gerenteId], references: [id])

  // === Filial ===
  filialId Int?    @map("filial_id")
  filial   Filial? @relation(fields: [filialId], references: [id])

  // === Conta (nullable — fila pode não ter dados suficientes) ===
  contaId Int?     @map("conta_id")
  conta   Account? @relation("AccountLeads", fields: [contaId], references: [id])

  // === Origem do registro ===
  fonte String? @default("crm")

  // === Timestamps ===
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? @map("deleted_at")
  canceladoEm DateTime? @map("cancelado_em")
  reativadoEm DateTime? @map("reativado_em")

  @@index([vendedorId])
  @@index([preVendedorId])
  @@index([gerenteId])
  @@index([filialId])
  @@index([contaId])
  @@index([status])
  @@index([temperatura])
  @@index([createdAt])
  @@map("leads")
}

model Account {
  id        Int    @id @default(autoincrement())
  nome      String
  sobrenome String
  celular   String
  cep       String

  // 1:N — Uma Conta pode ter muitos Leads
  leads Lead[] @relation("AccountLeads")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Índice composto para a regra de identificação cruzada (nome + celular + cep)
  @@unique([celular, nome, cep], name: "account_identity")
  @@map("accounts")
}

model Task {
  id             Int       @id @default(autoincrement())
  titulo         String
  descricao      String?
  status         String    @default("PENDENTE") // PENDENTE, CONCLUIDA
  dataVencimento DateTime?

  // Criador da tarefa
  createdById Int  @map("created_by_id")
  createdBy   User @relation("TaskCreator", fields: [createdById], references: [id])

  // Atribuição
  assignedToUserId Int?  @map("assigned_to_user_id")
  assignedToUser   User? @relation("AssignedTasks", fields: [assignedToUserId], references: [id])

  assignedToEquipeId Int?    @map("assigned_to_equipe_id")
  assignedToEquipe   Equipe? @relation("EquipeTasks", fields: [assignedToEquipeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToUserId])
  @@index([createdById])
  @@index([assignedToEquipeId])
  @@index([status])
  @@map("tasks")
}
